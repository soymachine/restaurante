---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div>
      <a href={base} class="brand" style="color: var(--ink); font-size: 1.6rem;">EN<em style="color: var(--copper-2); font-style: normal;">.</em></a>
      <p style="margin-top: 1rem; max-width: 28ch;">Root cooking, local produce and slow fire. A table to celebrate the everyday.</p>
    </div>
    <div>
      <h4>Visit us</h4>
      <ul>
        <li>Rua do Crucifixo, 14</li>
        <li>1100 · Lisbon</li>
        <li>+351 210 000 000</li>
      </ul>
    </div>
    <div>
      <h4>Hours</h4>
      <ul>
        <li>Tue – Thu · 1–4pm / 8–11pm</li>
        <li>Fri – Sat · 1–4pm / 8pm–midnight</li>
        <li>Sun · 1–4pm</li>
      </ul>
    </div>
    <div>
      <h4>Social</h4>
      <ul>
        <li><a href="#">Instagram</a></li>
        <li><a href="#">The Fork</a></li>
        <li><a href="#">Newsletter</a></li>
      </ul>
    </div>
    <div class="legal" style="grid-column: 1 / -1;">
      <span>© {year} EN · All rights reserved</span>
      <span>Design by the house</span>
    </div>
  </div>
</footer>
