---
import Layout from '../layouts/Layout.astro';
import { fetchMenu, type WpMenuCategory } from '../lib/wp';

const fallback: WpMenuCategory[] = [
  {
    nombre: 'To start',
    descripcion: 'Small bites designed to open the table and the conversation.',
    platos: [
      { nombre: 'Citrus-brined olives', descripcion: 'House-cured manzanilla with blood orange zest.', precio: '6' },
      { nombre: 'Bluefin tuna tartare', descripcion: 'Garden pickles, smoked bone oil and fresh wasabi.', precio: '22' },
      { nombre: 'Free-range hen croquettes', descripcion: 'Made with 24-hour stock. Five pieces, not one more.', precio: '14' },
      { nombre: 'Tomato in its own juice', descripcion: 'Raf tomato, Cantabrian anchovy, purple basil.', precio: '16' },
    ],
  },
  {
    nombre: 'From the garden',
    descripcion: 'Vegetables treated with the same intensity as a fine cut of meat.',
    platos: [
      { nombre: 'Grilled artichoke', descripcion: 'Holm oak charcoal, cured egg yolk, light romesco.', precio: '18' },
      { nombre: 'Carnaroli and mushroom risotto', descripcion: 'Pyrenean boletus, noisette butter, 36-month parmesan.', precio: '24' },
      { nombre: 'Smoked aubergine', descripcion: 'Chickpea miso, pomegranate and toasted seeds.', precio: '17' },
    ],
  },
  {
    nombre: 'From the fire',
    descripcion: 'Meat and fish passed through the coals. Time, salt, patience.',
    platos: [
      { nombre: 'Twelve-hour lamb', descripcion: 'Milk-fed lamb, mountain herbs, rosemary honey.', precio: '32' },
      { nombre: 'Wild sea bass in salt crust', descripcion: 'Salt crust, fennel, confit lemon, seasonal vegetables.', precio: '36' },
      { nombre: 'Rubia Gallega beef tenderloin', descripcion: '45-day aged, concentrated jus, soufflé potato.', precio: '38' },
      { nombre: 'Grilled octopus', descripcion: 'Purple potato, light saffron aioli.', precio: '28' },
    ],
  },
  {
    nombre: 'To finish',
    descripcion: 'Small, intense desserts, made with the neighbourhood pastry chef.',
    platos: [
      { nombre: 'Chocolate soufflé', descripcion: '72% Madagascar cacao, bourbon vanilla ice cream, gold dust.', precio: '12' },
      { nombre: 'Melted cheese tart', descripcion: 'Idiazábal, red fruits macerated in sherry vinegar.', precio: '11' },
      { nombre: 'Citrus in syrup', descripcion: 'Blood orange, grapefruit, kumquat, mandarin sorbet.', precio: '10' },
    ],
  },
];

const categories = (await fetchMenu()) ?? fallback;
---

<Layout title="Menú — EN">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 03 / Menu</span>
      <h1 data-reveal-lines>What we think is <em>good</em> today.</h1>
      <p class="fade-up" style="margin-top: 1.6rem; color: var(--ink-dim);">The menu changes with the season. This is what we are cooking this week.</p>
    </div>
  </section>

  <div class="wrap">
    {categories.map((cat) => (
      <article class="menu-cat fade-up">
        <header>
          <h2>{cat.nombre}</h2>
          <p class="cat-desc">{cat.descripcion}</p>
        </header>
        <div class="menu-items">
          {cat.platos.map((it) => (
            <div class="menu-item">
              <h3>{it.nombre}</h3>
              <div class="price">{it.precio} €</div>
              <p class="desc">{it.descripcion}</p>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>

  <section class="cta">
    <div class="wrap">
      <h2 data-reveal-lines>Hungry <em>already</em>.</h2>
      <a href={`${import.meta.env.BASE_URL}reservas`} class="btn fade-up" style="margin-top: 2rem;">Reserve a table <span class="arrow">→</span></a>
    </div>
  </section>
</Layout>
