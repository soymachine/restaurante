---
import Layout from '../layouts/Layout.astro';
import { fetchMenu, type WpMenuCategory } from '../lib/wp';

const fallback: WpMenuCategory[] = [
  {
    nombre: 'Para empezar',
    descripcion: 'Pequeños bocados pensados para abrir la mesa y la conversación.',
    platos: [
      { nombre: 'Aceitunas en salmuera de cítricos', descripcion: 'Manzanilla cacereña curada en casa con piel de naranja sanguina.', precio: '6' },
      { nombre: 'Tartar de atún rojo', descripcion: 'Encurtidos de la huerta, aceite de hueso ahumado y wasabi fresco.', precio: '22' },
      { nombre: 'Croquetas de gallina vieja', descripcion: 'Hechas con caldo de 24 horas. Cinco unidades, ni una más.', precio: '14' },
      { nombre: 'Tomate en su jugo', descripcion: 'Tomate raf de Almería, anchoa del Cantábrico, albahaca morada.', precio: '16' },
    ],
  },
  {
    nombre: 'De la huerta',
    descripcion: 'Vegetales tratados con la misma intensidad que un buen lomo.',
    platos: [
      { nombre: 'Alcachofa a la brasa', descripcion: 'Carbón de encina, yema curada, romesco ligero.', precio: '18' },
      { nombre: 'Risotto carnaroli y hongos', descripcion: 'Boletus del Pirineo, mantequilla noisette, parmesano 36 meses.', precio: '24' },
      { nombre: 'Berenjena ahumada', descripcion: 'Miso de garbanzo, granada y semillas tostadas.', precio: '17' },
    ],
  },
  {
    nombre: 'Del fuego',
    descripcion: 'Carne y pescado pasados por brasa. Tiempo, sal, paciencia.',
    platos: [
      { nombre: 'Cordero a doce horas', descripcion: 'Lechal de Lanzarote, hierbas serranas, miel de romero.', precio: '32' },
      { nombre: 'Lubina salvaje en sal', descripcion: 'Costra de sal, hinojo, limón confitado, verduras de temporada.', precio: '36' },
      { nombre: 'Solomillo de vaca rubia', descripcion: 'Maduración 45 días, jugo concentrado, patata soufflé.', precio: '38' },
      { nombre: 'Pulpo a la brasa', descripcion: 'Patata violeta, alioli ligero de azafrán.', precio: '28' },
    ],
  },
  {
    nombre: 'Para terminar',
    descripcion: 'Postres pequeños, intensos, hechos con la pastelera del barrio.',
    platos: [
      { nombre: 'Soufflé de chocolate', descripcion: 'Cacao 72% de Madagascar, helado de vainilla bourbon, polvo de oro.', precio: '12' },
      { nombre: 'Tarta de queso fundida', descripcion: 'Idiazábal, frutos rojos macerados en vinagre de Jerez.', precio: '11' },
      { nombre: 'Cítricos en almíbar', descripcion: 'Naranja sanguina, pomelo, kumquat, sorbete de mandarina.', precio: '10' },
    ],
  },
];

const categories = (await fetchMenu()) ?? fallback;
---

<Layout title="Menú — Bracero">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 03 / Menú</span>
      <h1 data-reveal-lines>Lo que <em>hoy</em> nos parece bueno.</h1>
      <p class="fade-up" style="margin-top: 1.6rem; color: var(--ink-dim);">La carta cambia con la temporada. Esto es lo que cocinamos esta semana.</p>
    </div>
  </section>

  <div class="wrap">
    {categories.map((cat) => (
      <article class="menu-cat fade-up">
        <header>
          <h2>{cat.nombre}</h2>
          <p class="cat-desc">{cat.descripcion}</p>
        </header>
        <div class="menu-items">
          {cat.platos.map((it) => (
            <div class="menu-item">
              <h3>{it.nombre}</h3>
              <div class="price">{it.precio} €</div>
              <p class="desc">{it.descripcion}</p>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>

  <section class="cta">
    <div class="wrap">
      <h2 data-reveal-lines>Hambre <em>ya</em>.</h2>
      <a href={`${import.meta.env.BASE_URL}reservas`} class="btn fade-up" style="margin-top: 2rem;">Reservar mesa <span class="arrow">→</span></a>
    </div>
  </section>
</Layout>
