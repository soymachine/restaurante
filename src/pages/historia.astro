---
import Layout from '../layouts/Layout.astro';
const img = (id: string, w = 1600) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;
---
<Layout title="Story — Bracero">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 02 / Story</span>
      <h1 data-reveal-lines>Ten years cooking the same gesture.</h1>
    </div>
  </section>

  <section>
    <div class="wrap grid-2">
      <div class="story-text">
        <p class="fade-up">In 2014, Ana Ferreira opened the door of a small space in Mouraria with a stubborn idea: to cook whatever the market decided each morning. No menu, no certainties, no promise beyond the honesty of the ingredients.</p>
        <p class="fade-up">Today Bracero remains an intimate table, twelve guests per service, where the grill is the protagonist and the menu changes with the light of the year.</p>
        <p class="fade-up">We work with producers we call by name. Cheeses from the Alentejo. Vegetables from the Ribatejo. Fish that arrives on ice from the Atlantic coast. Natural wines from people who harvest by hand.</p>
      </div>
      <div class="frame" style="aspect-ratio: 3/4;">
        <img src={img('1438118907704-7718ee9a191a')} alt="Open kitchen" loading="lazy"/>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-2);">
    <div class="wrap">
      <span class="eyebrow fade-up">Philosophy</span>
      <h2 data-reveal-lines style="margin: 1rem 0 3rem; max-width: 18ch;">Three principles that hold every dish together.</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem;" class="principles">
        <div class="fade-up">
          <div style="font-family: var(--serif); font-size: 4rem; color: var(--copper-2); font-style: italic; margin-bottom: 1rem;">i</div>
          <h3 style="font-style: italic; margin-bottom: .8rem;">Season</h3>
          <p style="color: var(--ink-dim);">We cook what grows now. If it's not its month, it's not on the table.</p>
        </div>
        <div class="fade-up">
          <div style="font-family: var(--serif); font-size: 4rem; color: var(--copper-2); font-style: italic; margin-bottom: 1rem;">ii</div>
          <h3 style="font-style: italic; margin-bottom: .8rem;">Fire</h3>
          <p style="color: var(--ink-dim);">The grill sets the pace. Every dish passes through its right temperature.</p>
        </div>
        <div class="fade-up">
          <div style="font-family: var(--serif); font-size: 4rem; color: var(--copper-2); font-style: italic; margin-bottom: 1rem;">iii</div>
          <h3 style="font-style: italic; margin-bottom: .8rem;">Time</h3>
          <p style="color: var(--ink-dim);">Nothing is rushed. Doughs rest, stocks wait, and so do the guests.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 820px) { .principles { grid-template-columns: 1fr !important; } }
  </style>
</Layout>
