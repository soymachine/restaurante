---
import Layout from '../layouts/Layout.astro';
import { fetchReservationInfo } from '../lib/wp';

const img = (id: string, w = 1600) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;

const fallbackInfo = {
  telefono: '',
  email: 'hola@bracero.es',
  horarioComida: '13:00 – 15:30',
  horarioCena: '20:00 – 23:00',
  notas: 'Aforo reducido. Recomendamos reservar con antelación, especialmente fines de semana.',
};

const info = (await fetchReservationInfo()) ?? fallbackInfo;
---
<Layout title="Reservas — Bracero">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 05 / Reservas</span>
      <h1 data-reveal-lines>Una mesa, <em>tu</em> noche.</h1>
    </div>
  </section>

  <section>
    <div class="wrap grid-2">
      <div>
        <div class="reservas-info fade-up">
          {info.horarioComida && (
            <div class="info-row">
              <span class="info-label">Comida</span>
              <span>{info.horarioComida}</span>
            </div>
          )}
          {info.horarioCena && (
            <div class="info-row">
              <span class="info-label">Cena</span>
              <span>{info.horarioCena}</span>
            </div>
          )}
          {info.telefono && (
            <div class="info-row">
              <span class="info-label">Teléfono</span>
              <a href={`tel:${info.telefono.replace(/\s/g, '')}`} style="color: var(--copper-2);">{info.telefono}</a>
            </div>
          )}
        </div>

        {info.notas && (
          <p class="fade-up" style="color: var(--ink-dim); margin-bottom: 1rem;">{info.notas}</p>
        )}
        <p class="fade-up" style="color: var(--ink-dim);">Para grupos (hasta 12 personas) o menús privados, escríbenos a <a href={`mailto:${info.email}`} style="color: var(--copper-2);">{info.email}</a>.</p>

        <form class="form-grid fade-up" onsubmit="event.preventDefault(); this.querySelector('.confirm').style.opacity='1';">
          <div class="field">
            <label for="name">Nombre</label>
            <input id="name" type="text" required />
          </div>
          <div class="field">
            <label for="email">Correo</label>
            <input id="email" type="email" required />
          </div>
          <div class="field">
            <label for="date">Fecha</label>
            <input id="date" type="date" required />
          </div>
          <div class="field">
            <label for="time">Hora</label>
            <select id="time">
              <option>13:00</option><option>13:30</option><option>14:00</option><option>14:30</option>
              <option>20:00</option><option>20:30</option><option>21:00</option><option>21:30</option><option>22:00</option>
            </select>
          </div>
          <div class="field">
            <label for="people">Comensales</label>
            <select id="people">
              <option>1</option><option>2</option><option>3</option><option>4</option>
              <option>5</option><option>6</option><option>7</option><option>8</option>
            </select>
          </div>
          <div class="field">
            <label for="phone">Teléfono</label>
            <input id="phone" type="tel" />
          </div>
          <div class="field field-full">
            <label for="notes">Notas (alergias, ocasión...)</label>
            <textarea id="notes" rows="3"></textarea>
          </div>
          <div class="form-submit">
            <button class="btn" type="submit">Confirmar solicitud <span class="arrow">→</span></button>
            <p class="confirm" style="opacity: 0; color: var(--copper-2); margin-top: 1.5rem; font-family: var(--serif); font-style: italic; transition: opacity .6s var(--ease);">Recibido. Te escribimos en breve.</p>
          </div>
        </form>
      </div>
      <div class="frame" style="aspect-ratio: 3/4;">
        <img src={img('1414235077428-338989a2e8c0')} alt="Mesa preparada" loading="lazy"/>
      </div>
    </div>
  </section>
</Layout>

<style>
  .reservas-info {
    display: flex;
    flex-direction: column;
    gap: .6rem;
    margin-bottom: 1.8rem;
    padding: 1.4rem 1.8rem;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 4px;
  }
  .info-row {
    display: flex;
    gap: 1.2rem;
    font-size: .95rem;
    color: var(--ink-dim);
  }
  .info-label {
    width: 6rem;
    flex-shrink: 0;
    font-weight: 500;
    color: var(--copper-2);
    font-family: var(--sans);
    letter-spacing: .04em;
    font-size: .8rem;
    text-transform: uppercase;
    padding-top: .15em;
  }
</style>
