---
import Layout from '../layouts/Layout.astro';
const img = (id: string, w = 1400) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;

const shots = [
  '1414235077428-338989a2e8c0',
  '1517248135467-4c7edcad34c4',
  '1559339352-11d035aa65de',
  '1546069901-ba9599a7e63c',
  '1466637574441-749b8f19452f',
  '1438118907704-7718ee9a191a',
  '1424847651672-bf20a4b0982b',
  '1551024506-0bccd828d307',
  '1476124369491-e7addf5db371',
];
---
<Layout title="Galería — Bracero">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 04 / Galería</span>
      <h1 data-reveal-lines>El detalle, en imágenes.</h1>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="gal">
        {shots.map((id, i) => (
          <div class={`frame gal-${(i % 6) + 1}`}>
            <img src={img(id)} alt="" loading="lazy"/>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .gal {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.4rem;
    }
    .gal-1 { grid-column: span 7; aspect-ratio: 5/4; }
    .gal-2 { grid-column: span 5; aspect-ratio: 4/5; margin-top: 4rem; }
    .gal-3 { grid-column: span 4; aspect-ratio: 3/4; }
    .gal-4 { grid-column: span 4; aspect-ratio: 1/1; margin-top: 3rem; }
    .gal-5 { grid-column: span 4; aspect-ratio: 3/4; }
    .gal-6 { grid-column: span 6; aspect-ratio: 4/3; margin-top: 2rem; }
    @media (max-width: 820px) {
      .gal > * { grid-column: span 6 !important; margin-top: 0 !important; aspect-ratio: 4/5 !important; }
    }
  </style>
</Layout>
