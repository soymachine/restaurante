---
import Layout from '../layouts/Layout.astro';
import { fetchGallery } from '../lib/wp';

const unsplashImg = (id: string, w = 1400) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;

const fallbackShots = [
  { url: unsplashImg('1414235077428-338989a2e8c0'), alt: '' },
  { url: unsplashImg('1517248135467-4c7edcad34c4'), alt: '' },
  { url: unsplashImg('1559339352-11d035aa65de'), alt: '' },
  { url: unsplashImg('1546069901-ba9599a7e63c'), alt: '' },
  { url: unsplashImg('1466637574441-749b8f19452f'), alt: '' },
  { url: unsplashImg('1438118907704-7718ee9a191a'), alt: '' },
  { url: unsplashImg('1424847651672-bf20a4b0982b'), alt: '' },
  { url: unsplashImg('1551024506-0bccd828d307'), alt: '' },
  { url: unsplashImg('1476124369491-e7addf5db371'), alt: '' },
];

const wpGallery = await fetchGallery();
const shots = wpGallery ?? fallbackShots;
---
<Layout title="Galería — Bracero">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 04 / Galería</span>
      <h1 data-reveal-lines>El detalle, en imágenes.</h1>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="gal">
        {shots.map((shot, i) => (
          <div class={`frame gal-${(i % 6) + 1}`}>
            <img src={shot.url} alt={shot.alt} loading="lazy"/>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .gal {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.4rem;
    }
    .gal-1 { grid-column: span 7; aspect-ratio: 5/4; }
    .gal-2 { grid-column: span 5; aspect-ratio: 4/5; margin-top: 4rem; }
    .gal-3 { grid-column: span 4; aspect-ratio: 3/4; }
    .gal-4 { grid-column: span 4; aspect-ratio: 1/1; margin-top: 3rem; }
    .gal-5 { grid-column: span 4; aspect-ratio: 3/4; }
    .gal-6 { grid-column: span 6; aspect-ratio: 4/3; margin-top: 2rem; }
    @media (max-width: 820px) {
      .gal > * { grid-column: span 6 !important; margin-top: 0 !important; aspect-ratio: 4/5 !important; }
    }
  </style>
</Layout>
