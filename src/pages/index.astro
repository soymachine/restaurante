---
import Layout from '../layouts/Layout.astro';

const img = (id: string, w = 1600) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=${w}&q=80`;

const dishes = [
  { n: '01', name: 'Bluefin tuna tartare', desc: 'Garden pickles, bone oil and fresh wasabi.', img: '1546069901-ba9599a7e63c' },
  { n: '02', name: 'Slow-fire lamb', desc: 'Twelve hours over coals, mountain herbs and rosemary honey.', img: '1544025162-d76694265947' },
  { n: '03', name: 'Carnaroli risotto', desc: 'Valley mushrooms, noisette butter and 36-month parmesan.', img: '1476124369491-e7addf5db371' },
  { n: '04', name: 'Wild sea bass', desc: 'Salt crust, fennel, confit lemon and seasonal vegetables.', img: '1467003909585-2f8a72700288' },
  { n: '05', name: 'Chocolate soufflé', desc: '72% cacao, bourbon vanilla ice cream and gold dust.', img: '1551024506-0bccd828d307' },
];
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" data-hero-bg>
      <img src={img('1414235077428-338989a2e8c0')} alt="Table set by candlelight" loading="eager" />
    </div>
    <div class="wrap">
      <span class="eyebrow fade-up">Lisbon · Since 2014</span>
      <h1 data-hero-title>
        One table.<br />
        <em>A thousand</em> stories.
      </h1>
      <div class="hero-meta">
        <p class="fade-up">Root cooking with eyes set on the product, the fire, and time. An intimate experience at the heart of the neighbourhood.</p>
        <a href={`${import.meta.env.BASE_URL}reservas`} class="btn fade-up">
          Reserve a table
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
    <div class="scroll-hint">
      Desliza
      <span class="bar"></span>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" data-marquee>
    <div class="marquee-track">
      <span>Seasonal produce <i class="dot"></i> Oak fire <i class="dot"></i> Intimate dining <i class="dot"></i> Natural wines <i class="dot"></i></span>
      <span>Seasonal produce <i class="dot"></i> Oak fire <i class="dot"></i> Intimate dining <i class="dot"></i> Natural wines <i class="dot"></i></span>
    </div>
  </div>

  <!-- STORY -->
  <section id="historia">
    <span class="section-num">— 01 / Story</span>
    <div class="wrap grid-2">
      <div class="frame story-img-wrap">
        <img src={img('1466637574441-749b8f19452f')} alt="Chef at work" loading="lazy" />
      </div>
      <div class="story-text">
        <span class="eyebrow">Our story</span>
        <h2 data-reveal-lines>The flavour of the everyday elevated to ritual.</h2>
        <p class="fade-up">Bracero was born from an obsession with a simple gesture: cooking over fire with whatever the land offers that week. Ten years on, we still hand-pick every ingredient, every producer, every wine.</p>
        <p class="fade-up">There is no fixed menu. There is season, craft, and a conversation with whoever sits at the table.</p>
        <p class="sig fade-up">— Ana Ferreira, Chef</p>
      </div>
    </div>
  </section>

  <!-- DISHES horizontal -->
  <section class="dishes" id="cocina">
    <span class="section-num">— 02 / Kitchen</span>
    <div class="wrap">
      <div class="dishes-head">
        <h2 data-reveal-lines>Dishes that tell where we are.</h2>
        <p class="fade-up">Five proposals that change with the season. Bites designed to share, remember, and return for.</p>
      </div>
    </div>
    <div class="dishes-track" data-dishes-track>
      {dishes.map((d) => (
        <article class="dish">
          <div class="frame dish-img">
            <img src={img(d.img, 900)} alt={d.name} loading="lazy" />
          </div>
          <div class="dish-num">{d.n}</div>
          <h3>{d.name}</h3>
          <p>{d.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- GALLERY -->
  <section id="galeria">
    <span class="section-num">— 03 / Atmosphere</span>
    <div class="wrap">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; flex-wrap: wrap;">
        <h2 data-reveal-lines style="max-width: 16ch;">A space that breathes with the kitchen.</h2>
        <a href={`${import.meta.env.BASE_URL}galeria`} class="btn fade-up">View gallery <span class="arrow">→</span></a>
      </div>
      <div class="gallery-grid">
        <div class="frame g1"><img src={img('1517248135467-4c7edcad34c4')} alt="Dining room" loading="lazy"/></div>
        <div class="frame g2"><img src={img('1414235077428-338989a2e8c0')} alt="Table" loading="lazy"/></div>
        <div class="frame g3"><img src={img('1559339352-11d035aa65de')} alt="Wine" loading="lazy"/></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-bg">
      <img src={img('1424847651672-bf20a4b0982b')} alt="" loading="lazy"/>
    </div>
    <div class="wrap">
      <span class="eyebrow fade-up">Reservations</span>
      <h2 data-reveal-lines>A table <em>awaits</em>.</h2>
      <p class="fade-up">Limited seating. We recommend booking in advance, especially at weekends.</p>
      <a href={`${import.meta.env.BASE_URL}reservas`} class="btn fade-up">Book now <span class="arrow">→</span></a>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;

      // Hero entrance: split words of title manually
      const title = document.querySelector<HTMLElement>('[data-hero-title]');
      if (title) {
        const html = title.innerHTML;
        const parts = html.split('<br>');
        title.innerHTML = parts.map((line) => {
          const words = line.trim().split(/\s+/);
          return words.map((w) => `<span style="display:inline-block;overflow:hidden;vertical-align:top;"><span class="hero-w" style="display:inline-block;transform:translateY(110%);">${w}&nbsp;</span></span>`).join('');
        }).join('<br>');
        gsap.to('.hero-w', {
          y: 0,
          duration: 1.4,
          ease: 'expo.out',
          stagger: 0.08,
          delay: 0.1,
        });
      }

      // Hero bg parallax
      gsap.to('[data-hero-bg] img', {
        yPercent: 18,
        scale: 1.05,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero',
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      });

      // Marquee continuous scroll, accelerated by user scroll
      const track = document.querySelector<HTMLElement>('[data-marquee] .marquee-track');
      if (track) {
        const tween = gsap.to(track, {
          xPercent: -50,
          duration: 30,
          ease: 'none',
          repeat: -1,
        });
        ScrollTrigger.create({
          trigger: '[data-marquee]',
          start: 'top bottom',
          end: 'bottom top',
          onUpdate: (self: any) => {
            tween.timeScale(1 + Math.abs(self.getVelocity() / 1200));
          },
        });
      }

      // Horizontal pinned dishes
      const dt = document.querySelector<HTMLElement>('[data-dishes-track]');
      if (dt && window.innerWidth > 820) {
        const distance = dt.scrollWidth - window.innerWidth + 80;
        gsap.to(dt, {
          x: -distance,
          ease: 'none',
          scrollTrigger: {
            trigger: '.dishes',
            start: 'top top',
            end: () => `+=${distance + 200}`,
            scrub: 1,
            pin: true,
            anticipatePin: 1,
            invalidateOnRefresh: true,
          },
        });
      }
    });
  </script>
</Layout>
