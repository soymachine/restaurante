---
import Layout from '../../layouts/Layout.astro';
import { fetchPosts, fetchPost } from '../../lib/wp';

export async function getStaticPaths() {
  const posts = await fetchPosts(100);
  return posts.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const post = await fetchPost(slug);

if (!post) {
  return Astro.redirect(`${import.meta.env.BASE_URL}noticias`);
}

const base = import.meta.env.BASE_URL;

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={`${post.title} — Bracero`}>
  <section class="page-hero">
    <div class="wrap" style="max-width: 56rem;">
      <span class="eyebrow">
        <a href={`${base}noticias`} style="color: inherit; text-decoration: none; opacity: .6;">← News</a>
      </span>
      <time class="post-date fade-up" datetime={post.date}>{formatDate(post.date)}</time>
      <h1 data-reveal-lines set:html={post.title} />
    </div>
  </section>

  {post.featuredImage && (
    <div class="wrap" style="max-width: 72rem; margin-bottom: 4rem;">
      <div class="frame" style="aspect-ratio: 16/7;">
        <img src={post.featuredImage.url} alt={post.featuredImage.alt || post.title} loading="eager" />
      </div>
    </div>
  )}

  <section>
    <div class="wrap post-content" style="max-width: 56rem;">
      <Fragment set:html={post.content} />
    </div>
  </section>

  <section style="padding: 4rem 0 6rem;">
    <div class="wrap" style="max-width: 56rem;">
      <a href={`${base}noticias`} class="btn fade-up">← Back to news</a>
    </div>
  </section>
</Layout>

<style>
  .post-date {
    display: block;
    font-family: var(--sans);
    font-size: .8rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--copper-2);
    margin-bottom: 1rem;
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--ink-dim);
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    margin: 2.4rem 0 .8rem;
    line-height: 1.3;
  }

  .post-content :global(h2) { font-size: clamp(1.3rem, 2.5vw, 1.7rem); }
  .post-content :global(h3) { font-size: clamp(1.1rem, 2vw, 1.3rem); }

  .post-content :global(p) { margin-bottom: 1.4rem; }

  .post-content :global(a) {
    color: var(--copper-2);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .post-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: 2px;
    margin: 2rem 0;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--copper-2);
    padding-left: 1.4rem;
    margin: 2rem 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.4rem;
  }

  .post-content :global(li) { margin-bottom: .4rem; }
</style>
