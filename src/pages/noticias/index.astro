---
import Layout from '../../layouts/Layout.astro';
import { fetchPosts } from '../../lib/wp';

const posts = await fetchPosts(12);
const base = import.meta.env.BASE_URL;

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Novedades — Bracero" description="Últimas noticias y novedades de Bracero.">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">— 06 / Novedades</span>
      <h1 data-reveal-lines>Lo <em>último</em> de la casa.</h1>
    </div>
  </section>

  <section>
    <div class="wrap">
      {posts.length === 0 ? (
        <p style="color: var(--ink-dim); padding: 4rem 0; text-align: center; font-family: var(--serif); font-style: italic; font-size: 1.2rem;">
          Pronto habrá novedades por aquí.
        </p>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`${base}noticias/${post.slug}`} class="post-card fade-up">
              {post.featuredImage && (
                <div class="frame post-img">
                  <img src={post.featuredImage.url} alt={post.featuredImage.alt || post.title} loading="lazy" />
                </div>
              )}
              <div class="post-body">
                <time class="post-date" datetime={post.date}>{formatDate(post.date)}</time>
                <h2 set:html={post.title} />
                {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
                <span class="post-more">Leer más <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 34rem), 1fr));
    gap: 3.2rem 2.4rem;
    padding: 2rem 0 6rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover .post-more {
    color: var(--copper-2);
  }

  .post-card:hover .post-img img {
    transform: scale(1.04);
  }

  .post-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-img img {
    transition: transform .6s var(--ease);
  }

  .post-body {
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .post-date {
    font-family: var(--sans);
    font-size: .75rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--copper-2);
  }

  .post-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 400;
    line-height: 1.3;
  }

  .post-excerpt {
    color: var(--ink-dim);
    font-size: .95rem;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-more {
    font-family: var(--sans);
    font-size: .8rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-top: .4rem;
    transition: color .3s;
  }

  .arrow {
    display: inline-block;
    transition: transform .3s;
  }

  .post-card:hover .arrow {
    transform: translateX(4px);
  }
</style>
